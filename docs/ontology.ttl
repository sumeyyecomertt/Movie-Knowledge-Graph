@base <http://www.w3.org/2002/07/owl#> .

[ rdf:type owl:Ontology
 ] .

#################################################################
#    Annotation properties
#################################################################

###  http://www.semanticweb.org/movie-ontology#actedIn
<http://www.semanticweb.org/movie-ontology#actedIn> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/movie-ontology#directedBy
<http://www.semanticweb.org/movie-ontology#directedBy> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/movie-ontology#hasGenre
<http://www.semanticweb.org/movie-ontology#hasGenre> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/movie-ontology#hasScore
<http://www.semanticweb.org/movie-ontology#hasScore> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/movie-ontology#hasTitle
<http://www.semanticweb.org/movie-ontology#hasTitle> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/movie-ontology#releaseYear
<http://www.semanticweb.org/movie-ontology#releaseYear> rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/movie-ontology#Director
<http://www.semanticweb.org/movie-ontology#Director> rdf:type owl:Class .


###  http://www.semanticweb.org/movie-ontology#Genre
<http://www.semanticweb.org/movie-ontology#Genre> rdf:type owl:Class .


###  http://www.semanticweb.org/movie-ontology#Movie
<http://www.semanticweb.org/movie-ontology#Movie> rdf:type owl:Class .


###  http://www.semanticweb.org/movie-ontology#Person
<http://www.semanticweb.org/movie-ontology#Person> rdf:type owl:Class .


